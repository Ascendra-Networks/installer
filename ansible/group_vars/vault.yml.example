---
# Example Vault File for Tyr Deployment
# This file shows the structure for encrypted credentials
# 
# To create your own encrypted vault file:
#   1. Copy this file: cp vault.yml.example vault.yml
#   2. Edit vault.yml with your actual credentials
#   3. Encrypt it: ansible-vault encrypt vault.yml
#   4. Update group_vars/all.yml to reference these variables
#
# To use the vault file:
#   ansible-playbook -i inventory/dev.ini playbooks/tyr-deploy.yml --ask-vault-pass
#
# To edit the encrypted vault:
#   ansible-vault edit vault.yml

# GHCR (GitHub Container Registry) credentials
vault_tyr_ghcr_username: "your-github-username"
vault_tyr_ghcr_password: "ghp_YourGitHubPersonalAccessToken"

# Tyr version to deploy
vault_tyr_version: "1.0.0"

# Optional: Override default configurations
# vault_tyr_inframanager_namespace: "default"
# vault_tyr_github_token_secret_name: "gh-token"
# vault_tyr_kubevirt_image_tag: "v1.6.0-ascendra.1"
# vault_tyr_kubevirt_cpu_allocation_ratio: 4
# vault_tyr_kube_ovn_version: ""




