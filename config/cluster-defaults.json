{
  "version": "1.0.0",
  "description": "Shared cluster defaults used by Terraform and the installer backend",
  "network": {
    "vpc": {
      "cidr": "10.0.0.0/16",
      "nameSuffix": "-vpc",
      "enableDnsHostnames": true,
      "enableDnsSupport": true
    },
    "subnet": {
      "cidr": "10.0.1.0/24",
      "nameSuffix": "-subnet",
      "mapPublicIpOnLaunch": true
    }
  },
  "compute": {
    "master": {
      "instanceType": "t3.xlarge",
      "diskSize": 100,
      "diskType": "gp3"
    },
    "worker": {
      "defaultInstanceType": "t3.xlarge",
      "diskSize": 100,
      "diskType": "gp3"
    }
  },
  "ssh": {
    "keyAlgorithm": "RSA",
    "keyBits": 4096
  },
  "tags": {
    "managedBy": "Ascendra-Installer"
  }
}
